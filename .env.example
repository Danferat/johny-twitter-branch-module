# Twitter/X API user-context credentials.
# Get them in X Developer Console: https://console.x.com/
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Optional. Official current host is https://api.x.com.
# Legacy projects may still use https://api.twitter.com.
TWITTER_API_BASE_URL=https://api.x.com

# Host bot topic id. Prefer /setup_topics or /set_topic twitter instead of
# asking a user to paste numeric Telegram chat/user IDs.
TOPIC_TWITTER=0

